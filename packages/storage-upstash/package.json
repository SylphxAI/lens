{
  "name": "@sylphx/lens-storage-upstash",
  "version": "1.2.6",
  "description": "Upstash Redis storage adapter for Lens opLog plugin (HTTP-based)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bunup",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet'",
    "prepack": "[ -d dist ] || bun run build",
    "lint:fix": "biome check --write ."
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "lens",
    "storage",
    "upstash",
    "redis",
    "serverless",
    "edge"
  ],
  "author": "SylphxAI",
  "license": "MIT",
  "dependencies": {
    "@sylphx/lens-core": "workspace:*",
    "@sylphx/lens-server": "workspace:*"
  },
  "peerDependencies": {
    "@upstash/redis": ">=1.0.0"
  },
  "devDependencies": {
    "@upstash/redis": "^1.34.8",
    "typescript": "^7.0.2",
    "@biomejs/biome": "^2.3.12",
    "@sylphx/biome-config": "^0.4.1"
  }
}
