{
  "name": "@sylphx/lens-server",
  "version": "4.1.6",
  "description": "Server runtime for Lens API framework",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bunup",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepack": "[ -d dist ] || bun run build",
    "lint:fix": "biome check --write ."
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "lens",
    "server",
    "resolvers",
    "graphql"
  ],
  "author": "SylphxAI",
  "license": "MIT",
  "dependencies": {
    "@sylphx/lens-core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "zod": "^4.1.13",
    "@biomejs/biome": "^2.3.12",
    "@sylphx/biome-config": "^0.4.1"
  }
}
