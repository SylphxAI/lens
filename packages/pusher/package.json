{
  "name": "@sylphx/lens-pusher",
  "version": "1.2.1",
  "description": "Pusher Channels integration for Lens real-time subscriptions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bunup",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet'",
    "prepack": "[ -d dist ] || bun run build",
    "lint:fix": "biome check --write ."
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "lens",
    "pusher",
    "realtime",
    "serverless",
    "websocket"
  ],
  "author": "SylphxAI",
  "license": "MIT",
  "peerDependencies": {
    "pusher": ">=5.0.0",
    "pusher-js": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "pusher": {
      "optional": true
    },
    "pusher-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "pusher": "^5.2.0",
    "pusher-js": "^8.4.0",
    "typescript": "^7.0.2",
    "@biomejs/biome": "^2.3.12",
    "@sylphx/biome-config": "^0.4.1"
  }
}
